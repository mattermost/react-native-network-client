{
  "name": "@mattermost/react-native-network-client",
  "version": "1.10.0",
  "description": "Configurable network clients for React Native. Uses Alamofire for iOS and OkHttp3 for Android.",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "react-native-network-client.podspec",
    "!lib/typescript/example",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!example",
    "!.vscode",
    "!**/.idea",
    "!**/.gradle",
    "!android/build",
    "!ios/Build",
    "!.circleci"
  ],
  "scripts": {
    "test": "jest",
    "typescript": "tsc --noEmit",
    "lint": "eslint .",
    "prepare": "bob build && husky",
    "release": "release-it",
    "example": "cd example && npm",
    "pods": "cd example && pod-install --quiet",
    "bootstrap": "npm run example i && npm run pods"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "network"
  ],
  "repository": "https://github.com/mattermost/react-native-network-client",
  "author": "Miguel Alatzar <this.migbot@gmail.com> (https://github.com/migbot)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mattermost/react-native-network-client/issues"
  },
  "homepage": "https://github.com/mattermost/react-native-network-client#readme",
  "dependencies": {
    "validator": "13.15.35",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@babel/runtime": "7.29.2",
    "@commitlint/config-conventional": "20.5.0",
    "@release-it/conventional-changelog": "10.0.6",
    "@types/jest": "30.0.0",
    "@types/react": "19.2.14",
    "@types/validator": "13.15.10",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "commitlint": "20.5.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "pod-install": "1.0.15",
    "react": "19.2.5",
    "react-native": "0.83.6",
    "react-native-builder-bob": "0.41.0",
    "release-it": "20.0.0",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "codegenConfig": {
    "name": "NetworkClientSpec",
    "type": "modules",
    "jsSrcsDir": "./src",
    "android": {
      "javaPackageName:": "com.mattermost.networkclient"
    }
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(@react-native|react-native|validator)/)"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": false
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "conventionalcommits"
      }
    }
  },
  "overrides": {
    "@release-it/conventional-changelog": {
      "release-it": "$release-it"
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
